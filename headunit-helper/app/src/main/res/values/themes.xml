<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.WirelessHelper" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorPrimary">@color/brand_teal</item>
        <item name="colorSecondary">@color/brand_teal</item>
        <item name="colorAccent">@color/brand_teal</item>
        <item name="android:colorAccent">@color/brand_teal</item>
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:statusBarColor" tools:targetApi="21">@android:color/transparent</item>
        <item name="android:navigationBarColor" tools:targetApi="21">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <item name="android:dialogTheme">@style/DarkAlertDialog</item>
        <item name="android:alertDialogTheme">@style/DarkAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/DarkAlertDialog</item>
    </style>

    <style name="SplashTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/color_projection_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.WirelessHelper</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Headunit Revived Dialog Theme -->
    <style name="DarkAlertDialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/brand_teal</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/brand_teal</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:colorAccent">@color/brand_teal</item>
        
        <!-- Background Color -->
        <item name="colorSurface">@color/setting_background_color</item>
        <item name="android:background">@color/setting_background_color</item>
        
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        
        <!-- Button Styles -->
        <item name="buttonBarPositiveButtonStyle">@style/DialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButton.Negative</item>
    </style>

    <style name="DialogButton.Positive" parent="Widget.Material3.Button">
        <item name="android:textColor">@android:color/white</item>
        <item name="backgroundTint">@color/brand_teal</item>
    </style>

    <style name="DialogButton.Negative" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_teal</item>
        <item name="colorSecondary">@color/brand_teal</item>
    </style>

    <style name="ShapeAppearanceOverlay.HeadunitHelper.ActionButton" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.HeadunitHelper.Badge" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

</resources>

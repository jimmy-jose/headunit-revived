<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_content_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/launcher_setup_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_pill_translucent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/launcher_setup_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingEnd="12dp"
                    android:text="@string/launcher_setup_description"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/launcher_setup_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set_as_launcher"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/brand_teal"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_dashboard_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/clock_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill_translucent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/clock_time_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:00 AM"
                        android:textColor="@color/text_primary"
                        android:letterSpacing="-0.02"
                        android:shadowColor="@color/text_shadow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="10"
                        android:textFontWeight="800"
                        android:textSize="50sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/clock_day_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Wednesday"
                        android:textColor="@color/text_primary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textFontWeight="700"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/clock_date_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="May 13"
                        android:textColor="@color/text_primary"
                        android:textFontWeight="700"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/connection_card"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_translucent"
                    android:gravity="end"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/connection_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/connection"
                        android:textColor="@color/text_primary"
                        android:textFontWeight="700"
                        android:textSize="16sp" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/main_buttons_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/self_mode_button"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="6dp"
                            android:background="@drawable/gradient_teal"
                            android:elevation="4dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            app:backgroundTint="@null"
                            app:icon="@drawable/ic_launch_white"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="#ffffff"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintEnd_toStartOf="@+id/usb_button"
                            app:layout_constraintHorizontal_chainStyle="spread"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/self_mode_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:text="@string/self_mode"
                            android:textColor="@color/text_primary"
                            android:textFontWeight="700"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toEndOf="@+id/self_mode_button"
                            app:layout_constraintStart_toStartOf="@+id/self_mode_button"
                            app:layout_constraintTop_toBottomOf="@+id/self_mode_button" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/usb_button"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="6dp"
                            android:background="@drawable/gradient_rust"
                            android:elevation="4dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            app:backgroundTint="@null"
                            app:icon="@drawable/ic_usb_white"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="#ffffff"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/self_mode_button"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/usb_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:text="@string/usb"
                            android:textColor="@color/text_primary"
                            android:textFontWeight="700"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toEndOf="@+id/usb_button"
                            app:layout_constraintStart_toStartOf="@+id/usb_button"
                            app:layout_constraintTop_toBottomOf="@+id/usb_button" />

                        <androidx.constraintlayout.widget.Barrier
                            android:id="@+id/row1_barrier"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:barrierDirection="bottom"
                            app:constraint_referenced_ids="self_mode_text,usb_text" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/wifi_button"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="6dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/gradient_rose"
                            android:elevation="4dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            app:backgroundTint="@null"
                            app:icon="@drawable/ic_network_wifi_white"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="#ffffff"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintEnd_toStartOf="@+id/settings_button"
                            app:layout_constraintHorizontal_chainStyle="spread"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/row1_barrier" />

                        <TextView
                            android:id="@+id/wifi_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:text="@string/wifi"
                            android:textColor="@color/text_primary"
                            android:textFontWeight="700"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toEndOf="@+id/wifi_button"
                            app:layout_constraintStart_toStartOf="@+id/wifi_button"
                            app:layout_constraintTop_toBottomOf="@+id/wifi_button" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/settings_button"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="6dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/gradient_olive"
                            android:elevation="4dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            app:backgroundTint="@null"
                            app:icon="@drawable/ic_settings_white"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="#ffffff"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/wifi_button"
                            app:layout_constraintTop_toBottomOf="@+id/row1_barrier" />

                        <TextView
                            android:id="@+id/settings_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:text="@string/settings"
                            android:textColor="@color/text_primary"
                            android:textFontWeight="700"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toEndOf="@+id/settings_button"
                            app:layout_constraintStart_toStartOf="@+id/settings_button"
                            app:layout_constraintTop_toBottomOf="@+id/settings_button" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_actions_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exit_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exit"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/material_grey_700"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/app_drawer_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_pill_translucent"
        android:elevation="20dp"
        android:orientation="vertical"
        app:behavior_fitToContents="true"
        app:behavior_hideable="false"
        app:behavior_peekHeight="74dp"
        app:behavior_skipCollapsed="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:id="@+id/app_drawer_handle"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:background="@drawable/bg_pill_translucent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="44dp"
                android:layout_height="4dp"
                android:background="@color/text_second" />

            <ImageView
                android:id="@+id/app_drawer_chevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/open_app_drawer"
                android:src="@drawable/ic_arrow_up"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/app_drawer_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/app_drawer_search_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_apps"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:endIconMode="clear_text"
                app:startIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/app_drawer_search_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_apps_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="24dp" />

            <TextView
                android:id="@+id/home_apps_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="@string/no_apps_found"
                android:textColor="@color/adaptive_text_color"
                android:textSize="16sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
